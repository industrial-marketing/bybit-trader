{% extends 'base.html.twig' %}

{% block title %}Dashboard — Bybit Trader{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://s3.tradingview.com/tv.js"></script>
<script src="/assets/js/app.js"></script>
{% endblock %}

{% block content %}
<div class="dashboard">

    {# ── Header with actions ────────────────────────────────────── #}
    <div class="dashboard-header">
        <h2><i class="bi bi-bar-chart-fill"></i> Статистика</h2>
        <div class="dashboard-header-actions">
            <button id="refresh-btn" class="btn-secondary" title="Обновить данные">
                <i class="bi bi-arrow-clockwise"></i> Обновить
            </button>
            <button id="bot-tick-btn" class="btn-primary" title="Запустить один тик бота">
                <i class="bi bi-robot"></i> Запустить бота
            </button>
        </div>
    </div>

    <div id="bot-status-message" class="bot-status-message"></div>

    {# ── Key metrics bar ────────────────────────────────────────── #}
    <div class="stats-key-metrics">
        <span class="key-metric" id="key-today-pnl"><strong>Сегодня:</strong> <span>-</span></span>
        <span class="key-metric" id="key-7d-pnl"><strong>7д:</strong> <span>-</span></span>
        <span class="key-metric" id="key-all-pnl"><strong>Всё время:</strong> <span>-</span></span>
    </div>

    {# ── Mini equity chart ─────────────────────────────────────── #}
    <div class="mini-equity-block" style="margin-bottom:20px;">
        <div class="mini-equity-header" style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
            <h4 class="stats-group-title" style="margin:0;"><i class="bi bi-graph-up"></i> Equity Curve</h4>
            <select id="mini-equity-period" style="font-size:12px; padding:4px 8px; background:var(--panel); border:1px solid var(--border); border-radius:6px; color:var(--text);">
                <option value="7">7 дней</option>
                <option value="30" selected>30 дней</option>
                <option value="90">90 дней</option>
            </select>
        </div>
        <div class="chart-container" style="position:relative; height:100px; background:rgba(0,0,0,0.15); border-radius:8px; border:1px solid var(--border);">
            <canvas id="mini-equity-chart"></canvas>
        </div>
        <span class="mini-equity-hint" style="font-size:11px; color:var(--muted); margin-top:4px; display:block;">Накопленный PnL — тренд прибыльности</span>
    </div>

    {# ── Statistics: 4 logical groups ───────────────────────────── #}
    <div class="stats-groups">
        <div class="stats-group">
            <h4 class="stats-group-title"><i class="bi bi-wallet2"></i> Account</h4>
            <div class="stats-row">
                <div class="stat-card stat-card-main">
                    <span class="stat-label">Balance</span>
                    <span class="stat-value" id="stat-balance-usdt">-</span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Available</span>
                    <span class="stat-value" id="stat-balance-available">-</span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">In Positions</span>
                    <span class="stat-value" id="stat-margin-in-positions">-</span>
                </div>
                <div class="stat-card stat-card-pnl">
                    <span class="stat-label">Current PnL</span>
                    <span class="stat-value" id="stat-unrealised-pnl">-</span>
                </div>
            </div>
        </div>

        <div class="stats-group">
            <h4 class="stats-group-title"><i class="bi bi-layers"></i> Open Positions</h4>
            <div class="stats-row">
                <div class="stat-card">
                    <span class="stat-label">Positions</span>
                    <span class="stat-value" id="stat-open-positions-count">-</span>
                </div>
                <div class="stat-card" id="stat-margin-card">
                    <span class="stat-label">Margin Used</span>
                    <span class="stat-value" id="stat-margin-used">-</span>
                </div>
                <div class="stat-card" id="stat-exposure-card">
                    <span class="stat-label">Exposure</span>
                    <span class="stat-value" id="stat-exposure">-</span>
                </div>
                <div class="stat-card stat-card-pnl">
                    <span class="stat-label">Unrealized PnL</span>
                    <span class="stat-value" id="stat-unrealized-pnl">-</span>
                </div>
            </div>
        </div>

        <div class="stats-group">
            <h4 class="stats-group-title"><i class="bi bi-graph-up-arrow"></i> Trading Performance</h4>
            <div class="stats-row">
                <div class="stat-card stat-card-main">
                    <span class="stat-label">Total Profit</span>
                    <span class="stat-value" id="stat-total-profit">-</span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Win Rate</span>
                    <span class="stat-value" id="stat-win-rate">-</span>
                </div>
                <div class="stat-card" title="Сумма прибылей ÷ сумма убытков">
                    <span class="stat-label">Profit Factor</span>
                    <span class="stat-value" id="stat-profit-factor">-</span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Avg Profit</span>
                    <span class="stat-value" id="stat-avg-profit">-</span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Trades</span>
                    <span class="stat-value" id="stat-total-trades">-</span>
                </div>
            </div>
        </div>

        <div class="stats-group">
            <h4 class="stats-group-title"><i class="bi bi-shield-exclamation"></i> Risk Metrics</h4>
            <div class="stats-row">
                <div class="stat-card">
                    <span class="stat-label">Max Drawdown</span>
                    <span class="stat-value" id="stat-max-drawdown">-</span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Fees Paid</span>
                    <span class="stat-value" id="stat-total-fees">-</span>
                </div>
                <div class="stat-card" id="stat-avg-holding-card">
                    <span class="stat-label">Avg Holding</span>
                    <span class="stat-value" id="stat-avg-holding">-</span>
                </div>
            </div>
        </div>
    </div>
    <div id="stat-diagnostics" class="stat-diagnostics" style="display:none; margin-top:8px; padding:8px 12px; font-size:0.85rem; color:var(--muted, #666); background:rgba(0,0,0,0.05); border-radius:8px;">
        <span id="stat-source" title="Источник данных"></span>
        <span id="stat-note" style="margin-left:8px;"></span>
    </div>

    {# ── PnL charts ────────────────────────────────────────────── #}
    <div class="section pnl-charts-section" style="margin-top:20px;">
        <h3><i class="bi bi-graph-up"></i> PnL по дням и символам</h3>
        <div class="pnl-filters" style="display:flex; flex-wrap:wrap; gap:12px; align-items:center; margin-bottom:12px;">
            <label>Период: <select id="pnl-period"><option value="7">7</option><option value="30" selected>30</option><option value="90">90</option></select> дн.</label>
            <label>Группировка: <select id="pnl-group"><option value="day">По дням</option><option value="symbol">По символам</option></select></label>
            <label>Символ: <select id="pnl-symbol"><option value="">Все</option></select></label>
            <button id="pnl-refresh-btn" class="btn-secondary"><i class="bi bi-arrow-clockwise"></i> Обновить</button>
        </div>
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
            <div class="chart-container" style="position:relative; height:200px;">
                <canvas id="pnl-line-chart"></canvas>
            </div>
            <div class="chart-container" style="position:relative; height:200px;">
                <canvas id="pnl-bar-chart"></canvas>
            </div>
        </div>
        <div class="chart-container" style="position:relative; height:180px; margin-top:16px;">
            <canvas id="pnl-equity-chart"></canvas>
            <span style="position:absolute; left:8px; top:4px; font-size:11px; color:var(--muted,#666);">Equity (накопленный PnL) — тренд прибыльности стратегии</span>
        </div>
    </div>

    {# ── Chart & analysis block ────────────────────────────────── #}
    <div class="section" data-page="dashboard">
        <h2><i class="bi bi-graph-up"></i> Монета: график и анализ</h2>
        <div class="coin-block">
            <div class="coin-select-row">
                <label>Монета:</label>
                <select id="symbol-selector">
                    <option value="BTCUSDT">BTCUSDT</option>
                    <option value="ETHUSDT">ETHUSDT</option>
                    <option value="BNBUSDT">BNBUSDT</option>
                </select>
                <button id="analyze-btn" class="btn-primary">
                    <i class="bi bi-search"></i> Анализировать
                </button>
            </div>
            <div class="tv-chart-wrapper">
                <div id="tv-chart-container"></div>
            </div>
            <div id="analysis-result" class="analysis-card" style="display:none;"></div>
            <div id="decision-result" class="decision-card" style="display:none;"></div>
        </div>
    </div>

    {# ── Trade proposals ───────────────────────────────────────── #}
    <div class="section" data-page="dashboard">
        <h2><i class="bi bi-lightning-charge-fill"></i> Предложения по сделкам</h2>
        <p class="section-desc">Анализ топ-монет, отсортировано по вероятности удачности. Клик по строке — скорректировать сумму и открыть сделку с изолированной маржой.</p>
        <div class="proposals-toolbar">
            <button id="load-proposals-btn" class="btn-primary">
                <i class="bi bi-cpu"></i> Анализировать рынок
            </button>
        </div>
        <div class="table-container">
            <table id="proposals-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th>Сигнал</th>
                        <th>Уверенность</th>
                        <th>Сумма USDT</th>
                        <th>Плечо</th>
                        <th>Причина</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="7" class="loading">Нажмите «Анализировать рынок»</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Open order modal ──────────────────────────────────────── #}
    <div id="open-order-modal" class="modal" style="display: none;">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
            <h3><i class="bi bi-plus-circle" style="color:var(--brand-orange)"></i> Открыть сделку (изолированная маржа)</h3>
            <input type="hidden" id="modal-symbol" />
            <input type="hidden" id="modal-side" />
            <div class="form-group">
                <label>Символ</label>
                <input type="text" id="modal-symbol-display" readonly />
            </div>
            <div class="form-group">
                <label>Сторона</label>
                <input type="text" id="modal-side-display" readonly />
            </div>
            <div class="form-group">
                <label>Сумма (USDT)</label>
                <input type="number" step="0.01" min="1" id="modal-amount" value="10" />
            </div>
            <div class="form-group">
                <label>Плечо</label>
                <input type="number" min="1" id="modal-leverage" value="1" />
            </div>
            <div class="modal-actions">
                <button id="modal-submit-btn" class="btn-primary">
                    <i class="bi bi-check2-circle"></i> Открыть сделку
                </button>
                <button id="modal-cancel-btn" class="btn-secondary">
                    <i class="bi bi-x"></i> Отмена
                </button>
            </div>
            <div id="modal-message" class="message"></div>
        </div>
    </div>

    {# ── Top markets table ─────────────────────────────────────── #}
    <div class="section" data-page="dashboard">
        <h2><i class="bi bi-layers"></i> Топ монет (24ч оборот)</h2>
        <p class="section-desc">Клик по строке — выбрать монету для графика и анализа выше.</p>
        <div class="table-container">
            <table id="top-markets-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th class="num">Цена</th>
                        <th class="num">24ч %</th>
                        <th class="num">24ч объём</th>
                        <th class="num">24ч оборот</th>
                        <th class="num">High</th>
                        <th class="num">Low</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="7" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Risk guard status ─────────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-shield-fill-check"></i> Статус защиты бота</h2>
        <div id="risk-status-panel" class="risk-panel">
            <span class="loading">Загрузка...</span>
        </div>
    </div>

    {# ── Pending confirmations (strict mode) ───────────────────── #}
    <div class="section" data-page="bot" id="pending-section" style="display:none;">
        <h2><i class="bi bi-exclamation-triangle-fill" style="color:var(--warning)"></i> Ожидают подтверждения (строгий режим)</h2>
        <p class="section-desc">Эти действия предложены ботом, но требуют вашего подтверждения перед исполнением.</p>
        <div class="table-container">
            <table id="pending-table">
                <thead>
                    <tr>
                        <th>Время</th><th>Символ</th><th>Сторона</th>
                        <th>Действие</th><th>PnL</th><th>Примечание</th>
                        <th>Подтвердить</th><th>Отклонить</th>
                    </tr>
                </thead>
                <tbody><tr><td colspan="8" class="loading">Нет действий</td></tr></tbody>
            </table>
        </div>
    </div>

    {# ── Open positions ────────────────────────────────────────── #}
    <div class="section" data-page="bot">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:8px;">
            <div>
                <h2><i class="bi bi-collection-fill"></i> Текущие позиции</h2>
                <p class="section-desc">Клик по строке — показать график символа.</p>
            </div>
            <button type="button" id="positions-debug-btn" class="btn-secondary" style="font-size:0.85rem;" title="Проверить, что возвращает Bybit API">
                <i class="bi bi-bug"></i> Диагностика
            </button>
        </div>
        <div id="positions-debug-modal" class="modal" style="display:none;">
            <div class="modal-backdrop"></div>
            <div class="modal-content" style="max-width:520px; max-height:80vh; overflow:auto;">
                <h3><i class="bi bi-bug"></i> Диагностика позиций</h3>
                <pre id="positions-debug-output" style="margin:12px 0; padding:12px; background:rgba(0,0,0,0.3); border-radius:8px; font-size:12px; white-space:pre-wrap; word-break:break-all;"></pre>
                <button type="button" class="btn-secondary" id="positions-debug-close">Закрыть</button>
            </div>
        </div>
        <div class="table-container">
            <table id="positions-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th>Сторона</th>
                        <th class="num">Размер</th>
                        <th class="num">Вход USDT</th>
                        <th class="num">Маржа</th>
                        <th class="num">Плечо</th>
                        <th class="num">Цена входа</th>
                        <th class="num">Текущая</th>
                        <th class="num">Ликвидация</th>
                        <th class="num">PnL</th>
                        <th>Открыто</th>
                        <th>Почему?</th>
                        <th>Бот</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="14" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
        <div class="positions-chart-block" style="margin-top:16px;">
            <div class="coin-select-row" style="margin-bottom:8px;">
                <label>График позиции:</label>
                <select id="bot-chart-symbol">
                    <option value="">— выберите или кликните по строке —</option>
                </select>
            </div>
            <div class="tv-chart-wrapper tv-chart-wrapper-bot" id="tv-chart-wrapper-bot">
                <div id="tv-chart-container-bot"></div>
                <div class="chart-resize-handle" id="bot-chart-resize-handle" title="Потяните для изменения высоты графика">
                    <i class="bi bi-grip-horizontal"></i>
                </div>
            </div>
        </div>
    </div>

    {# ── Bot metrics ───────────────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-activity"></i> Метрики бота</h2>
        <p class="section-desc">Статистика решений LLM: предложено / исполнено / пропущено правилами.</p>
        <div id="bot-metrics-panel" class="metrics-panel">
            <div class="metrics-summary" id="metrics-summary-cards">
                <span class="loading">Загрузка метрик...</span>
            </div>
            <div class="metrics-by-action" id="metrics-by-action" style="margin-top:14px;"></div>
            <div class="metrics-skip-reasons" id="metrics-skip-reasons" style="margin-top:14px;"></div>
            <div id="metrics-data-path" class="metrics-data-path" style="margin-top:8px;font-size:11px;color:#6e7681;" title="Cron и web должны использовать этот же путь — иначе статистика не обновится"></div>
        </div>
    </div>

    {# ── LLM decisions trace ───────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-list-check"></i> Последние решения LLM (трасса)</h2>
        <p class="section-desc">Полная история решений с причинами, уверенностью и результатами правил.</p>
        <div class="table-container">
            <table id="decisions-table">
                <thead>
                    <tr>
                        <th>Время</th>
                        <th>Символ</th>
                        <th>Действие</th>
                        <th class="num">%</th>
                        <th>Риск</th>
                        <th>Причина LLM</th>
                        <th>Правило</th>
                        <th class="num">PnL est.</th>
                        <th>v</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="9" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Open orders ───────────────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-card-checklist"></i> Открытые ордера</h2>
        <div class="table-container">
            <table id="orders-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th>Сторона</th>
                        <th>Тип</th>
                        <th class="num">Цена</th>
                        <th class="num">Количество</th>
                        <th class="num">Исполнено</th>
                        <th>Статус</th>
                        <th>Создан</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="8" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Trades history ────────────────────────────────────────── #}
    <div class="section" data-page="history">
        <h2><i class="bi bi-arrow-left-right"></i> Последние сделки</h2>
        <div class="trades-toolbar" style="display:flex; flex-wrap:wrap; gap:12px; align-items:center; margin-bottom:12px;">
            <label>Период: <select id="trades-period"><option value="today">Сегодня</option><option value="24h">24ч</option><option value="7d">7 дней</option><option value="all" selected>Всё</option></select></label>
            <label>Показать: <select id="trades-limit"><option value="25">25</option><option value="50" selected>50</option><option value="100">100</option></select></label>
            <button id="trades-refresh-btn" class="btn-secondary" title="Обновить"><i class="bi bi-arrow-clockwise"></i></button>
            <span id="trades-pagination" style="margin-left:auto;"></span>
        </div>
        <div id="trades-summary" class="trades-summary" style="display:flex; flex-wrap:wrap; gap:20px; margin-bottom:16px; padding:16px 20px; background:rgba(0,0,0,0.08); border-radius:8px; align-items:center;">
            <span><strong>Сегодня PnL:</strong> <span id="trades-today-pnl" class="stat-value">-</span></span>
            <span><strong>Сделок:</strong> <span id="trades-count">-</span></span>
            <span><strong>Винрейт:</strong> <span id="trades-winrate">-</span>%</span>
            <span><strong>Ср. ROI:</strong> <span id="trades-avg-roi">-</span>%</span>
            <span><strong>Лучшая:</strong> <span id="trades-best">-</span></span>
            <span><strong>Худшая:</strong> <span id="trades-worst">-</span></span>
            <span><strong>Ср. комиссия:</strong> <span id="trades-avg-fee">-</span></span>
            <span><strong>Ср. длит.:</strong> <span id="trades-avg-dur">-</span></span>
        </div>
        <div class="table-container">
            <table id="trades-table">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="symbol">Символ</th>
                        <th class="sortable" data-sort="side">Сторона</th>
                        <th class="num sortable" data-sort="entryPrice">Вход</th>
                        <th class="num sortable" data-sort="exitPrice">Выход</th>
                        <th class="num sortable" data-sort="positionSizeUsdt">Position</th>
                        <th class="num sortable" data-sort="leverage">Lev</th>
                        <th class="num sortable" data-sort="closedPnl">PnL</th>
                        <th class="num sortable" data-sort="roiPct">ROI %</th>
                        <th class="num">Комиссия</th>
                        <th>Статус</th>
                        <th class="sortable" data-sort="durationMs">Длит.</th>
                        <th class="sortable" data-sort="closedAt">Закрыто</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="12" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Bot event history ─────────────────────────────────────── #}
    <div class="section" data-page="history">
        <h2><i class="bi bi-journal-text"></i> История бота (последние решения)</h2>
        <p class="section-desc">Здесь отображаются недавние решения и действия бота за последнюю неделю.</p>
        <div class="table-container">
            <table id="bot-history-table">
                <thead>
                    <tr>
                        <th>Время</th>
                        <th>Тип</th>
                        <th>Символ</th>
                        <th>Действие</th>
