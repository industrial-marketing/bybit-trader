{% extends 'base.html.twig' %}

{% block title %}Dashboard — Bybit Trader{% endblock %}

{% block scripts %}
<script src="https://s3.tradingview.com/tv.js"></script>
<script src="/assets/js/app.js"></script>
{% endblock %}

{% block content %}
<div class="dashboard">

    {# ── Header with actions ────────────────────────────────────── #}
    <div class="dashboard-header">
        <h2><i class="bi bi-bar-chart-fill"></i> Статистика</h2>
        <div class="dashboard-header-actions">
            <button id="refresh-btn" class="btn-secondary" title="Обновить данные">
                <i class="bi bi-arrow-clockwise"></i> Обновить
            </button>
            <button id="bot-tick-btn" class="btn-primary" title="Запустить один тик бота">
                <i class="bi bi-robot"></i> Запустить бота
            </button>
        </div>
    </div>

    <div id="bot-status-message" class="bot-status-message"></div>

    {# ── Statistics cards ───────────────────────────────────────── #}
    <div class="stats-grid">
        <div class="stat-card">
            <h3><i class="bi bi-wallet2"></i> Баланс USDT</h3>
            <p id="stat-balance-usdt">-</p>
        </div>
        <div class="stat-card">
            <h3><i class="bi bi-cash"></i> Доступно USDT</h3>
            <p id="stat-balance-available">-</p>
        </div>
        <div class="stat-card">
            <h3><i class="bi bi-arrow-left-right"></i> Всего сделок</h3>
            <p id="stat-total-trades">-</p>
        </div>
        <div class="stat-card">
            <h3><i class="bi bi-trophy"></i> Винрейт</h3>
            <p id="stat-win-rate">-</p>
        </div>
        <div class="stat-card">
            <h3><i class="bi bi-graph-up-arrow"></i> Общая прибыль</h3>
            <p id="stat-total-profit" class="profit">-</p>
        </div>
        <div class="stat-card">
            <h3><i class="bi bi-calculator"></i> Средняя прибыль</h3>
            <p id="stat-avg-profit">-</p>
        </div>
        <div class="stat-card">
            <h3><i class="bi bi-graph-down-arrow"></i> Макс. просадка</h3>
            <p id="stat-max-drawdown" class="loss">-</p>
        </div>
        <div class="stat-card">
            <h3><i class="bi bi-percent"></i> Профит-фактор</h3>
            <p id="stat-profit-factor">-</p>
        </div>
    </div>

    {# ── Chart & analysis block ────────────────────────────────── #}
    <div class="section" data-page="dashboard">
        <h2><i class="bi bi-graph-up"></i> Монета: график и анализ</h2>
        <div class="coin-block">
            <div class="coin-select-row">
                <label>Монета:</label>
                <select id="symbol-selector">
                    <option value="BTCUSDT">BTCUSDT</option>
                    <option value="ETHUSDT">ETHUSDT</option>
                    <option value="BNBUSDT">BNBUSDT</option>
                </select>
                <button id="analyze-btn" class="btn-primary">
                    <i class="bi bi-search"></i> Анализировать
                </button>
            </div>
            <div class="tv-chart-wrapper">
                <div id="tv-chart-container"></div>
            </div>
            <div id="analysis-result" class="analysis-card" style="display:none;"></div>
            <div id="decision-result" class="decision-card" style="display:none;"></div>
        </div>
    </div>

    {# ── Trade proposals ───────────────────────────────────────── #}
    <div class="section" data-page="dashboard">
        <h2><i class="bi bi-lightning-charge-fill"></i> Предложения по сделкам</h2>
        <p class="section-desc">Анализ топ-монет, отсортировано по вероятности удачности. Клик по строке — скорректировать сумму и открыть сделку с изолированной маржой.</p>
        <div class="proposals-toolbar">
            <button id="load-proposals-btn" class="btn-primary">
                <i class="bi bi-cpu"></i> Анализировать рынок
            </button>
        </div>
        <div class="table-container">
            <table id="proposals-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th>Сигнал</th>
                        <th>Уверенность</th>
                        <th>Сумма USDT</th>
                        <th>Плечо</th>
                        <th>Причина</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="7" class="loading">Нажмите «Анализировать рынок»</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Open order modal ──────────────────────────────────────── #}
    <div id="open-order-modal" class="modal" style="display: none;">
        <div class="modal-backdrop"></div>
        <div class="modal-content">
            <h3><i class="bi bi-plus-circle" style="color:var(--brand-orange)"></i> Открыть сделку (изолированная маржа)</h3>
            <input type="hidden" id="modal-symbol" />
            <input type="hidden" id="modal-side" />
            <div class="form-group">
                <label>Символ</label>
                <input type="text" id="modal-symbol-display" readonly />
            </div>
            <div class="form-group">
                <label>Сторона</label>
                <input type="text" id="modal-side-display" readonly />
            </div>
            <div class="form-group">
                <label>Сумма (USDT)</label>
                <input type="number" step="0.01" min="1" id="modal-amount" value="10" />
            </div>
            <div class="form-group">
                <label>Плечо</label>
                <input type="number" min="1" id="modal-leverage" value="1" />
            </div>
            <div class="modal-actions">
                <button id="modal-submit-btn" class="btn-primary">
                    <i class="bi bi-check2-circle"></i> Открыть сделку
                </button>
                <button id="modal-cancel-btn" class="btn-secondary">
                    <i class="bi bi-x"></i> Отмена
                </button>
            </div>
            <div id="modal-message" class="message"></div>
        </div>
    </div>

    {# ── Top markets table ─────────────────────────────────────── #}
    <div class="section" data-page="dashboard">
        <h2><i class="bi bi-layers"></i> Топ монет (24ч оборот)</h2>
        <p class="section-desc">Клик по строке — выбрать монету для графика и анализа выше.</p>
        <div class="table-container">
            <table id="top-markets-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th class="num">Цена</th>
                        <th class="num">24ч %</th>
                        <th class="num">24ч объём</th>
                        <th class="num">24ч оборот</th>
                        <th class="num">High</th>
                        <th class="num">Low</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="7" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Risk guard status ─────────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-shield-fill-check"></i> Статус защиты бота</h2>
        <div id="risk-status-panel" class="risk-panel">
            <span class="loading">Загрузка...</span>
        </div>
    </div>

    {# ── Pending confirmations (strict mode) ───────────────────── #}
    <div class="section" data-page="bot" id="pending-section" style="display:none;">
        <h2><i class="bi bi-exclamation-triangle-fill" style="color:var(--warning)"></i> Ожидают подтверждения (строгий режим)</h2>
        <p class="section-desc">Эти действия предложены ботом, но требуют вашего подтверждения перед исполнением.</p>
        <div class="table-container">
            <table id="pending-table">
                <thead>
                    <tr>
                        <th>Время</th><th>Символ</th><th>Сторона</th>
                        <th>Действие</th><th>PnL</th><th>Примечание</th>
                        <th>Подтвердить</th><th>Отклонить</th>
                    </tr>
                </thead>
                <tbody><tr><td colspan="8" class="loading">Нет действий</td></tr></tbody>
            </table>
        </div>
    </div>

    {# ── Open positions ────────────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-collection-fill"></i> Текущие позиции</h2>
        <div class="table-container">
            <table id="positions-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th>Сторона</th>
                        <th class="num">Размер</th>
                        <th class="num">Вход USDT</th>
                        <th class="num">Плечо</th>
                        <th class="num">Цена входа</th>
                        <th class="num">Текущая</th>
                        <th class="num">Ликвидация</th>
                        <th class="num">PnL</th>
                        <th>Открыто</th>
                        <th>Почему?</th>
                        <th>Бот</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="13" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Bot metrics ───────────────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-activity"></i> Метрики бота</h2>
        <p class="section-desc">Статистика решений LLM: предложено / исполнено / пропущено правилами.</p>
        <div id="bot-metrics-panel" class="metrics-panel">
            <div class="metrics-summary" id="metrics-summary-cards">
                <span class="loading">Загрузка метрик...</span>
            </div>
            <div class="metrics-by-action" id="metrics-by-action" style="margin-top:14px;"></div>
            <div class="metrics-skip-reasons" id="metrics-skip-reasons" style="margin-top:14px;"></div>
        </div>
    </div>

    {# ── LLM decisions trace ───────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-list-check"></i> Последние решения LLM (трасса)</h2>
        <p class="section-desc">Полная история решений с причинами, уверенностью и результатами правил.</p>
        <div class="table-container">
            <table id="decisions-table">
                <thead>
                    <tr>
                        <th>Время</th>
                        <th>Символ</th>
                        <th>Действие</th>
                        <th class="num">%</th>
                        <th>Риск</th>
                        <th>Причина LLM</th>
                        <th>Правило</th>
                        <th class="num">PnL est.</th>
                        <th>v</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="9" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Open orders ───────────────────────────────────────────── #}
    <div class="section" data-page="bot">
        <h2><i class="bi bi-card-checklist"></i> Открытые ордера</h2>
        <div class="table-container">
            <table id="orders-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th>Сторона</th>
                        <th>Тип</th>
                        <th class="num">Цена</th>
                        <th class="num">Количество</th>
                        <th class="num">Исполнено</th>
                        <th>Статус</th>
                        <th>Создан</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="8" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Trades history ────────────────────────────────────────── #}
    <div class="section" data-page="history">
        <h2><i class="bi bi-arrow-left-right"></i> Последние сделки</h2>
        <div class="table-container">
            <table id="trades-table">
                <thead>
                    <tr>
                        <th>Символ</th>
                        <th>Сторона</th>
                        <th class="num">Цена</th>
                        <th class="num">Количество</th>
                        <th class="num">Прибыль</th>
                        <th>Статус</th>
                        <th>Время</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="7" class="loading">Загрузка...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    {# ── Bot event history ─────────────────────────────────────── #}
    <div class="section" data-page="history">
        <h2><i class="bi bi-journal-text"></i> История бота (последние решения)</h2>
        <p class="section-desc">Здесь отображаются недавние решения и действия бота за последнюю неделю.</p>
        <div class="table-container">
            <table id="bot-history-table">
                <thead>
                    <tr>
                        <th>Время</th>
                        <th>Тип</th>
                        <th>Символ</th>
                        <th>Действие</th>
                        <th>Результат</th>
                        <th>Примечание</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="6" class="loading">Загрузка истории бота...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}
