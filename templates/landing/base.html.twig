<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Bybit Trader — AI-Powered Trading{% endblock %}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/brand/icons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/brand/icons/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/brand/icons/apple-touch-icon.png">
    <link rel="shortcut icon" href="/assets/brand/bybit_trader_icon.png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/assets/css/style.css">
    <style>
        .landing-nav { background: linear-gradient(135deg, #0B1220 0%, #1B2A41 100%); border-bottom: 2px solid rgba(245,158,11,0.3); padding: 12px 0; position: sticky; top: 0; z-index: 100; }
        .landing-nav .container { display: flex; justify-content: space-between; align-items: center; }
        .landing-nav a { color: var(--muted); text-decoration: none; padding: 8px 14px; border-radius: 6px; font-size: 14px; transition: color 0.2s, background 0.2s; }
        .landing-nav a:hover { color: var(--brand-orange); background: rgba(245,158,11,0.1); }
        .landing-nav .nav-cta { display: flex; gap: 10px; align-items: center; }
        .landing-nav .nav-burger { display: none; width: 36px; height: 36px; padding: 8px; background: none; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; cursor: pointer; flex-direction: column; justify-content: center; gap: 5px; }
        .landing-nav .nav-burger span { display: block; width: 100%; height: 2px; background: var(--muted); transition: var(--transition); border-radius: 2px; }
        .landing-nav .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .landing-nav .nav-burger.open span:nth-child(2) { opacity: 0; }
        .landing-nav .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
        @media (max-width: 900px) {
            .landing-nav .nav-burger { display: flex; }
            .landing-nav .nav-cta { display: none; position: absolute; top: 100%; left: 0; right: 0; flex-direction: column; background: #0B1220; border-bottom: 2px solid rgba(245,158,11,0.3); padding: 16px; gap: 4px; box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
            .landing-nav .nav-cta.open { display: flex; }
            .landing-nav .container { position: relative; }
        }
        .landing-nav .btn-landing { background: var(--brand-orange); color: var(--brand-navy); padding: 8px 18px; border-radius: 8px; font-weight: 600; }
        .landing-nav .btn-landing:hover { background: #d4a00a; color: var(--brand-navy); }
        .landing-nav .btn-landing.btn-outline { background: transparent !important; border: 1px solid var(--brand-orange); color: var(--brand-orange) !important; }
        .landing-nav .btn-landing.btn-outline:hover { background: rgba(245,158,11,0.15) !important; color: var(--brand-orange) !important; }
        .landing-hero { padding: 80px 0 100px; text-align: center; }
        .landing-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: var(--text); margin-bottom: 20px; line-height: 1.2; }
        .landing-hero h1 span { color: var(--brand-orange); }
        .landing-hero .subtitle { font-size: 1.15rem; color: var(--muted); max-width: 560px; margin: 0 auto 16px; line-height: 1.6; }
        .landing-hero .hero-trust { font-size: 0.9rem; color: var(--muted); opacity: 0.9; margin: 0 auto 36px; line-height: 1.5; }
        .landing-dashboard-preview .dashboard-preview-label { font-size: 0.85rem; color: var(--muted); padding: 12px 16px; border-bottom: 1px solid var(--border); text-align: center; }
        .landing-hero .hero-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
        .landing-hero .btn-hero { padding: 14px 28px; border-radius: 10px; font-size: 1rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: transform 0.2s, box-shadow 0.2s; }
        .landing-hero .btn-primary { background: var(--brand-orange); color: var(--brand-navy); border: none; }
        .landing-hero .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(245,158,11,0.35); }
        .landing-hero .btn-secondary { background: transparent; color: var(--brand-orange); border: 1px solid var(--brand-orange); }
        .landing-hero .btn-secondary:hover { background: rgba(245,158,11,0.1); border-color: var(--brand-orange); color: var(--brand-orange); }
        .landing-section { padding: 60px 0; border-top: 1px solid var(--border); }
        .landing-section h2 { font-size: 1.75rem; color: var(--text); margin-bottom: 12px; }
        .landing-section .section-subtitle { color: var(--muted); margin-bottom: 40px; }
        .landing-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; max-width: 960px; margin: 0 auto; }
        .landing-step { text-align: center; padding: 24px; background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); }
        .landing-step .step-num { width: 48px; height: 48px; background: rgba(245,158,11,0.2); color: var(--brand-orange); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; margin: 0 auto 16px; }
        .landing-step h4 { font-size: 1rem; margin-bottom: 8px; }
        .landing-step p { font-size: 0.9rem; color: var(--muted); }
        .landing-features { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; max-width: 960px; margin: 0 auto; }
        .landing-feature { padding: 28px; background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); }
        .landing-feature i { font-size: 1.75rem; color: var(--brand-orange); margin-bottom: 16px; }
        .landing-feature h4 { font-size: 1.1rem; margin-bottom: 10px; }
        .landing-feature p { font-size: 0.9rem; color: var(--muted); line-height: 1.5; }
        .landing-ai-models { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
        .landing-ai-model { padding: 20px 32px; background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); font-weight: 600; }
        .landing-security { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
        .landing-security-item { display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--panel); border-radius: var(--radius); }
        .landing-security-item i { color: var(--positive); font-size: 1.25rem; }
        .landing-faq { max-width: 640px; margin: 0 auto; }
        .landing-faq-item { padding: 20px 0; border-bottom: 1px solid var(--border); }
        .landing-faq-item h5 { font-size: 1rem; margin-bottom: 8px; }
        .landing-faq-item p { font-size: 0.9rem; color: var(--muted); }
        .landing-cta { text-align: center; padding: 80px 0; }
        .landing-cta h2 { font-size: 1.75rem; margin-bottom: 16px; }
        .landing-cta p { color: var(--muted); margin-bottom: 28px; }
        .landing-footer { padding: 40px 0; border-top: 1px solid var(--border); }
        .landing-footer .container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
        .landing-footer .footer-links { display: flex; gap: 24px; }
        .landing-footer a { color: var(--muted); font-size: 0.9rem; }
        .landing-footer a:hover { color: var(--brand-orange); }
        .landing-hero .hero-trust { font-size: 0.9rem; color: var(--muted); margin: -8px auto 28px; opacity: 0.9; }
        .landing-dashboard-preview { max-width: 900px; margin: 48px auto 0; background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
        .landing-dashboard-preview .dashboard-preview-label { padding: 12px 16px; background: rgba(0,0,0,0.2); font-size: 0.85rem; color: var(--muted); text-align: center; }
        .landing-dashboard-preview img { width: 100%; height: auto; display: block; }
        .landing-dashboard-preview .placeholder { height: 280px; background: linear-gradient(135deg, #0F1B2D 0%, #1B2A41 100%); display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 1rem; padding: 24px; text-align: center; }
        .landing-img-grid { display: grid; grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(3, 1fr); gap: 0; max-width: 960px; margin: 0 auto 40px; }
        .landing-img-block { overflow: hidden; }
        .landing-img-block img { width: 100%; height: auto; display: block; object-fit: cover; }
        @media (max-width: 900px) { .landing-steps, .landing-features { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 600px) { .landing-img-grid { grid-template-columns: 1fr; } }
        @media (max-width: 500px) { .landing-steps, .landing-features { grid-template-columns: 1fr; } .landing-logo { height: 48px !important; } }
        .landing-nav .landing-logo { height: 72px; }
        @media (max-width: 900px) { .landing-nav .landing-logo { height: 56px; } }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    <nav class="landing-nav">
        <div class="container">
            <a href="/" class="navbar-brand" style="padding: 4px 8px;">
                <img src="/assets/brand/bybit_trader_logo.png" alt="Bybit Trader" class="brand-logo landing-logo">
            </a>
            <button type="button" class="nav-burger" id="landing-nav-burger" aria-label="Menu"><span></span><span></span><span></span></button>
            <div class="nav-cta" id="landing-nav-menu">
                <a href="#features">Features</a>
                <a href="#how-it-works">How it works</a>
                <a href="#security">Security</a>
                <a href="#faq">FAQ</a>
                <a href="/login" class="btn-landing btn-outline">Login</a>
                <a href="/register" class="btn-landing">Create Account</a>
            </div>
        </div>
    </nav>

    {% block content %}{% endblock %}

    <script>
    (function() {
        var burger = document.getElementById('landing-nav-burger');
        var menu = document.getElementById('landing-nav-menu');
        if (burger && menu) {
            burger.addEventListener('click', function() {
                burger.classList.toggle('open');
                menu.classList.toggle('open');
            });
            menu.querySelectorAll('a').forEach(function(a) {
                a.addEventListener('click', function() {
                    burger.classList.remove('open');
                    menu.classList.remove('open');
                });
            });
        }
    })();
    </script>
    <footer class="landing-footer">
        <div class="container">
            <div class="footer-brand" style="display:flex;flex-direction:column;align-items:flex-start;gap:4px;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <img src="/assets/brand/bybit_trader_icon.png" alt="BT" style="height:28px;">
                    <span style="font-weight:600;">Bybit Trader</span>
                </div>
                <span style="color:var(--muted);font-size:0.9rem;">AI-powered trading automation for Bybit.</span>
            </div>
            <div class="footer-links">
                <a href="/login">Login</a>
                <a href="/register">Register</a>
            </div>
            <span style="color:var(--muted);font-size:0.85rem;">© {{ "now"|date("Y") }} Bybit Trader</span>
        </div>
    </footer>
</body>
</html>
