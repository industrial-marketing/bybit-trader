{% extends 'base.html.twig' %}

{% block title %}Настройки — Bybit Trader{% endblock %}

{% block scripts %}
<script src="/assets/js/settings.js"></script>
{% endblock %}

{% block content %}
<div class="settings">

    <div class="dashboard-header" style="margin-bottom:24px;">
        <h2><i class="bi bi-gear-fill"></i> Настройки</h2>
    </div>

    {# ── Bybit API ────────────────────────────────────────────── #}
    <div class="settings-section">
        <h3><i class="bi bi-plug-fill"></i> Bybit API</h3>
        <form id="bybit-settings-form">
            <div class="form-group">
                <label>API Key:</label>
                <input type="text" id="bybit-api-key" name="api_key" placeholder="Введите API Key" autocomplete="off">
            </div>
            <div class="form-group">
                <label>API Secret:</label>
                <input type="password" id="bybit-api-secret" name="api_secret" placeholder="Введите API Secret" autocomplete="off">
            </div>
            <div class="form-group">
                <label>Base URL:</label>
                <input type="text" id="bybit-base-url" name="base_url" placeholder="https://api-testnet.bybit.com">
            </div>
            <div class="form-group">
                <input type="checkbox" id="bybit-testnet" name="testnet" checked>
                <span>Использовать тестовую сеть (Testnet)</span>
            </div>
            <div class="buttons-row">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-floppy-fill"></i> Сохранить
                </button>
                <button type="button" id="bybit-test-btn" class="btn-secondary">
                    <i class="bi bi-wifi"></i> Проверить подключение
                </button>
            </div>
        </form>
    </div>

    {# ── ChatGPT API ──────────────────────────────────────────── #}
    <div class="settings-section">
        <h3><i class="bi bi-stars"></i> ChatGPT API</h3>
        <form id="chatgpt-settings-form">
            <div class="form-group">
                <label>API Key:</label>
                <input type="text" id="chatgpt-api-key" name="api_key" placeholder="Введите OpenAI API Key" autocomplete="off">
            </div>
            <div class="form-group">
                <label>Модель:</label>
                <select id="chatgpt-model" name="model">
                    <option value="gpt-4o">GPT-4o</option>
                    <option value="gpt-4">GPT-4</option>
                    <option value="gpt-3.5-turbo">GPT-3.5 Turbo</option>
                </select>
            </div>
            <div class="form-group">
                <input type="checkbox" id="chatgpt-enabled" name="enabled">
                <span>Использовать ChatGPT для анализа</span>
            </div>
            <div class="buttons-row">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-floppy-fill"></i> Сохранить
                </button>
                <button type="button" id="chatgpt-test-btn" class="btn-secondary">
                    <i class="bi bi-wifi"></i> Проверить подключение
                </button>
            </div>
        </form>
    </div>

    {# ── DeepSeek API ─────────────────────────────────────────── #}
    <div class="settings-section">
        <h3><i class="bi bi-cpu-fill"></i> DeepSeek API (альтернативный LLM)</h3>
        <form id="deepseek-settings-form">
            <div class="form-group">
                <label>API Key:</label>
                <input type="text" id="deepseek-api-key" name="api_key" placeholder="Введите DeepSeek API Key" autocomplete="off">
            </div>
            <div class="form-group">
                <label>Модель:</label>
                <select id="deepseek-model" name="model">
                    <option value="deepseek-chat">deepseek-chat</option>
                    <option value="deepseek-reasoner">deepseek-reasoner</option>
                </select>
            </div>
            <div class="form-group">
                <input type="checkbox" id="deepseek-enabled" name="enabled">
                <span>Использовать DeepSeek, если ChatGPT недоступен</span>
            </div>
            <div class="buttons-row">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-floppy-fill"></i> Сохранить
                </button>
                <button type="button" id="deepseek-test-btn" class="btn-secondary">
                    <i class="bi bi-wifi"></i> Проверить подключение
                </button>
            </div>
        </form>
    </div>

    {# ── Trading parameters ────────────────────────────────────── #}
    <div class="settings-section">
        <h3><i class="bi bi-sliders"></i> Торговые параметры</h3>
        <form id="trading-settings-form">
            <div class="form-group">
                <label>Максимальный размер сделки (USDT):</label>
                <input type="number" step="0.01" min="0" id="trading-max-position" name="max_position_usdt" placeholder="Например, 100">
            </div>
            <div class="form-group">
                <label>Минимальное плечо:</label>
                <input type="number" min="1" id="trading-min-leverage" name="min_leverage" placeholder="Например, 1">
            </div>
            <div class="form-group">
                <label>Максимальное плечо:</label>
                <input type="number" min="1" id="trading-max-leverage" name="max_leverage" placeholder="Например, 5">
            </div>
            <div class="form-group">
                <label>Агрессивность:</label>
                <select id="trading-aggressiveness" name="aggressiveness">
                    <option value="conservative">Консервативная</option>
                    <option value="balanced">Сбалансированная</option>
                    <option value="aggressive">Агрессивная</option>
                </select>
            </div>
            <div class="form-group">
                <label>Максимум позиций под управлением бота:</label>
                <input type="number" min="1" id="trading-max-managed" name="max_managed_positions" placeholder="Например, 10">
            </div>
            <div class="form-group">
                <label>Минимум открытых позиций для автооткрытия ботом:</label>
                <input type="number" min="0" id="trading-auto-open-min" name="auto_open_min_positions" placeholder="Например, 5">
            </div>
            <div class="form-group">
                <input type="checkbox" id="trading-auto-open-enabled" name="auto_open_enabled">
                <span>Разрешить боту самостоятельно открывать сделки, если позиций меньше порога</span>
            </div>
            <div class="form-group">
                <label>Таймфрейм бота (частота принятия решений):</label>
                <select id="trading-bot-timeframe" name="bot_timeframe">
                    <option value="1">1 мин (скальпинг)</option>
                    <option value="5">5 мин</option>
                    <option value="15">15 мин</option>
                    <option value="30">30 мин</option>
                    <option value="60">1 час</option>
                    <option value="240">4 часа</option>
                    <option value="1440">1 день</option>
                </select>
                <span class="hint">Бот запускается каждую минуту, но принимает решения только раз в выбранный период.</span>
            </div>
            <div class="form-group">
                <label>Свечей истории для анализа (макс. 60):</label>
                <input type="number" min="5" max="60" id="trading-history-candles" name="bot_history_candles" placeholder="60">
                <span class="hint">Сколько последних свечей выбранного таймфрейма передавать боту при каждом анализе.</span>
            </div>
            <div class="buttons-row">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-floppy-fill"></i> Сохранить
                </button>
            </div>
        </form>
    </div>

    {# ── Risk Guards ───────────────────────────────────────────── #}
    <div class="settings-section" style="border-color: rgba(239,68,68,0.4);">
        <h3 style="color: var(--negative);"><i class="bi bi-shield-exclamation" style="color:var(--negative)"></i> Защита от потерь (Risk Guards)</h3>
        <form id="risk-settings-form">
            <div class="form-group">
                <input type="checkbox" id="risk-trading-enabled" name="trading_enabled" checked>
                <span><strong>Торговля разрешена</strong> — снимите галочку, чтобы заблокировать ВСЕ торговые операции.</span>
            </div>
            <div class="form-group">
                <label>Дневной лимит потерь (USDT):</label>
                <input type="number" step="0.01" min="0" id="risk-daily-loss" name="daily_loss_limit_usdt" placeholder="0 = отключено">
                <span class="hint">Если суммарный PnL за день опустится ниже −X USDT, бот автоматически остановится.</span>
            </div>
            <div class="form-group">
                <label>Максимальный суммарный риск (USDT маржи):</label>
                <input type="number" step="0.01" min="0" id="risk-max-exposure" name="max_total_exposure_usdt" placeholder="0 = отключено">
                <span class="hint">Сумма всех маржинальных залогов (notional/leverage). Если превышена — новые позиции не открываются.</span>
            </div>
            <div class="form-group">
                <label>Кулдаун между действиями по символу (мин):</label>
                <input type="number" min="0" id="risk-cooldown" name="action_cooldown_minutes" placeholder="30">
                <span class="hint">Минимальный интервал между торговыми действиями по одной монете. 0 — без ограничений.</span>
            </div>
            <div class="form-group">
                <input type="checkbox" id="risk-strict-mode" name="bot_strict_mode">
                <span><strong>Строгий режим:</strong> CLOSE_FULL и AVERAGE_IN требуют ручного подтверждения.</span>
            </div>
            <div class="form-group">
                <input type="checkbox" id="risk-canary-mode" name="canary_mode">
                <span><strong>Canary-режим:</strong> ВСЕ действия бота идут в ожидание подтверждения. Включать при изменении промпта/стратегии.</span>
            </div>
            <div class="form-group">
                <label>Мин. множитель edge над издержками (fees+slip+funding):</label>
                <input type="number" step="0.1" min="0" id="risk-min-edge-mult" name="min_edge_multiplier" placeholder="2">
                <span class="hint">Действие блокируется, если edge &lt; costs × этот множитель. 0 = отключено.</span>
            </div>
            <div class="buttons-row">
                <button type="submit" class="btn-danger">
                    <i class="bi bi-floppy-fill"></i> Сохранить
                </button>
            </div>
        </form>
    </div>

    {# ── Circuit Breaker ───────────────────────────────────────── #}
    <div class="settings-section" id="cb-section" style="border-color: rgba(245,158,11,0.4);">
        <h3><i class="bi bi-lightning-charge-fill" style="color:var(--warning)"></i> Circuit Breaker (авто-пауза при сбоях)</h3>
        <p class="section-desc">Автоматически приостанавливает торговлю при серии ошибок Bybit или LLM. Возобновляется через <em>cooldown</em> или вручную.</p>

        <div id="cb-status-banner" style="display:none; margin-bottom:12px; padding:10px 14px; border-radius:8px; font-size:0.9rem;"></div>

        <form id="cb-settings-form">
            <div class="form-group">
                <input type="checkbox" id="cb-enabled" name="cb_enabled" checked>
                <span><strong>Circuit Breaker включён</strong></span>
            </div>
            <div class="form-group">
                <label>Порог ошибок Bybit API (подряд):</label>
                <input type="number" min="1" max="50" id="cb-bybit-threshold" name="cb_bybit_threshold" value="5">
                <span class="hint">После N подряд ошибок Bybit — торговля паузируется.</span>
            </div>
            <div class="form-group">
                <label>Порог сбоев LLM (подряд):</label>
                <input type="number" min="1" max="50" id="cb-llm-threshold" name="cb_llm_threshold" value="3">
            </div>
            <div class="form-group">
                <label>Порог невалидных ответов LLM (подряд):</label>
                <input type="number" min="1" max="50" id="cb-llm-invalid-threshold" name="cb_llm_invalid_threshold" value="5">
            </div>
            <div class="form-group">
                <label>Cooldown после срабатывания (мин):</label>
                <input type="number" min="1" max="1440" id="cb-cooldown" name="cb_cooldown_minutes" value="30">
                <span class="hint">После паузы бот автоматически продолжит работу.</span>
            </div>
            <div class="buttons-row">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-floppy-fill"></i> Сохранить
                </button>
                <button type="button" id="cb-status-btn" class="btn-secondary">
                    <i class="bi bi-activity"></i> Статус
                </button>
                <button type="button" id="cb-reset-btn" class="btn-secondary" style="color:var(--warning)">
                    <i class="bi bi-arrow-counterclockwise"></i> Сбросить все
                </button>
            </div>
        </form>
    </div>

    {# ── Alerts ────────────────────────────────────────────────── #}
    <div class="settings-section" style="border-color: rgba(16,185,129,0.3);">
        <h3><i class="bi bi-bell-fill" style="color:var(--positive)"></i> Алерты (Telegram / Webhook)</h3>
        <p class="section-desc">Получайте уведомления о сбоях LLM, ошибках Bybit, превышении лимитов риска.</p>
        <form id="alerts-settings-form">
            <div class="form-group">
                <label>Telegram Bot Token:</label>
                <input type="text" id="alerts-tg-token" name="telegram_bot_token" placeholder="123456:ABCdef...">
            </div>
            <div class="form-group">
                <label>Telegram Chat ID:</label>
                <input type="text" id="alerts-tg-chat" name="telegram_chat_id" placeholder="-1001234567890">
                <span class="hint">Узнать chat_id: добавьте бота в группу и проверьте /api/getUpdates</span>
            </div>
            <div class="form-group">
                <label>Webhook URL (Slack / Discord / Custom):</label>
                <input type="text" id="alerts-webhook" name="webhook_url" placeholder="https://hooks.slack.com/...">
            </div>
            <div class="form-group">
                <input type="checkbox" id="alerts-llm-failure" name="on_llm_failure" checked>
                <span>Уведомлять о сбоях LLM</span>
            </div>
            <div class="form-group">
                <input type="checkbox" id="alerts-invalid-resp" name="on_invalid_response" checked>
                <span>Уведомлять о невалидных ответах LLM</span>
            </div>
            <div class="form-group">
                <input type="checkbox" id="alerts-risk-limit" name="on_risk_limit" checked>
                <span>Уведомлять о превышении лимитов риска</span>
            </div>
            <div class="form-group">
                <input type="checkbox" id="alerts-bybit-error" name="on_bybit_error">
                <span>Уведомлять об ошибках Bybit API</span>
            </div>
            <div class="form-group">
                <input type="checkbox" id="alerts-repeated" name="on_repeated_failures" checked>
                <span>Уведомлять о повторяющихся ошибках</span>
            </div>
            <div class="form-group">
                <label>Порог повторяющихся ошибок (подряд):</label>
                <input type="number" min="1" id="alerts-threshold" name="repeated_failure_threshold" value="3">
            </div>
            <div class="buttons-row">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-floppy-fill"></i> Сохранить
                </button>
                <button type="button" id="test-alert-btn" class="btn-secondary">
                    <i class="bi bi-send"></i> Тестовый алерт
                </button>
            </div>
        </form>
    </div>

    <div id="settings-message" class="message"></div>
</div>
{% endblock %}
