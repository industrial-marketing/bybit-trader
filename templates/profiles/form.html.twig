{% extends 'base.html.twig' %}

{% block title %}{{ profile ? 'Edit' : 'New' }} Profile — Bybit Trader{% endblock %}

{% block content %}
<div class="profiles-form">
    <div class="dashboard-header" style="margin-bottom:24px;">
        <h2><i class="bi bi-person-badge-fill"></i> {{ profile ? 'Edit Profile' : 'New Profile' }}</h2>
    </div>

    {% for message in app.flashes('error') %}
        <div class="flash flash-error" style="margin-bottom:16px; padding:12px 16px; background:rgba(239,68,68,0.2); border:1px solid rgba(239,68,68,0.4); border-radius:8px; color:var(--negative);">
            {{ message }}
        </div>
    {% endfor %}

    <form method="post" action="{{ profile ? path('profiles_edit', {id: profile.id}) : path('profiles_create') }}" style="max-width:400px;">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('profile_form') }}">
        <div class="form-group">
            <label for="name">Profile name</label>
            <input type="text" id="name" name="name" value="{{ name }}" required minlength="2" placeholder="e.g. Main Testnet">
        </div>
        <div class="form-group">
            <label for="environment">Environment</label>
            <select id="environment" name="environment">
                <option value="testnet" {{ environment == 'testnet' ? 'selected' : '' }}>Testnet</option>
                <option value="mainnet" {{ environment == 'mainnet' ? 'selected' : '' }}>Mainnet (Real)</option>
            </select>
        </div>
        <div class="buttons-row" style="margin-top:20px;">
            <button type="submit" class="btn-primary">
                <i class="bi bi-check2-circle"></i> {{ profile ? 'Save' : 'Create' }}
            </button>
            <a href="{{ path('profiles_list') }}" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
{% endblock %}
