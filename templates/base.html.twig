<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Bybit Trader{% endblock %}</title>

    {# Favicons — place generated files in public/assets/brand/icons/ #}
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/brand/icons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/brand/icons/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/brand/icons/apple-touch-icon.png">
    <link rel="shortcut icon" href="/assets/brand/bybit_trader_icon.png">

    {# Bootstrap Icons CDN #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="/assets/css/style.css">
    <script src="/assets/lib/jquery.min.js"></script>
    <script>
    window.showToast = function(text, type) {
        type = type || 'info';
        var $c = $('#toast-container');
        if (!$c.length) return;
        var $t = $('<div class="toast toast-' + type + '"></div>').text(text);
        $c.append($t);
        setTimeout(function() { $t.addClass('toast-show'); }, 10);
        setTimeout(function() {
            $t.addClass('toast-hide');
            setTimeout(function() { $t.remove(); }, 300);
        }, 4000);
    };
    </script>
    {% block scripts %}{% endblock %}
    <style>
    .profile-dropdown { position: relative; }
    .profile-dropdown-btn { background: none; border: none; cursor: pointer; padding: 6px 12px; color: var(--muted, #9CA3AF); font-size: 13px; display: flex; align-items: center; gap: 6px; }
    .profile-dropdown-btn:hover { color: var(--brand-white, #fff); }
    .profile-dropdown-menu { display: none; position: absolute; top: 100%; left: 0; margin-top: 4px; background: var(--panel, #0F1B2D); border: 1px solid var(--border, rgba(255,255,255,0.08)); border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.4); min-width: 220px; z-index: 1000; }
    .profile-dropdown.open .profile-dropdown-menu { display: block; }
    .profile-option { display: block; padding: 10px 14px; color: var(--text, #E5E7EB); text-decoration: none; border-bottom: 1px solid var(--border); }
    .profile-option:last-child { border-bottom: none; }
    .profile-option:hover { background: rgba(255,255,255,0.06); }
    .profile-option.active { background: rgba(245,158,11,0.15); font-weight: 600; color: var(--brand-orange, #F59E0B); }
    .profile-chevron { font-size: 10px; transition: transform 0.2s; }
    .profile-dropdown.open .profile-chevron { transform: rotate(180deg); }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <a class="navbar-brand" href="/">
                <img
                    src="/assets/brand/bybit_trader_logo.png"
                    alt="Bybit Trader"
                    class="brand-logo"
                    onerror="this.style.background='transparent';this.src='';this.alt='BYBIT TRADER';this.style.fontSize='16px';this.style.fontWeight='700';this.style.color='#F59E0B';"
                >
            </a>
            <ul>
                <li>
                    <a href="/app?page=dashboard" title="Dashboard">
                        <i class="bi bi-bar-chart-fill"></i>
                        <span class="nav-label">Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="/app?page=bot" title="Bot">
                        <i class="bi bi-robot"></i>
                        <span class="nav-label">Bot</span>
                    </a>
                </li>
                <li>
                    <a href="/app?page=history" title="History">
                        <i class="bi bi-clock-history"></i>
                        <span class="nav-label">History</span>
                    </a>
                </li>
                <li>
                    <a href="/profiles" title="Profiles">
                        <i class="bi bi-person-badge"></i>
                        <span class="nav-label">Profiles</span>
                    </a>
                </li>
                {% if app_profiles is defined and app_profiles|length > 0 %}
                <li class="nav-profile-select">
                    <div class="profile-dropdown">
                        <button type="button" class="profile-dropdown-btn" id="profile-dropdown-btn" title="Trading profile">
                            <i class="bi bi-person-badge-fill"></i>
                            <span class="nav-label">{{ app_active_profile_name|default('File') }}</span>
                            <i class="bi bi-chevron-down profile-chevron"></i>
                        </button>
                        <div class="profile-dropdown-menu" id="profile-dropdown-menu">
                            {% for p in app_profiles %}
                            <a href="#" class="profile-option{% if app_active_profile_id == p.id %} active{% endif %}" data-profile-id="{{ p.id }}">
                                {% if p.id == 0 %}📁 {% endif %}{{ p.name }}{% if p.environment %}{{ ' (' ~ p.environment ~ ')' }}{% endif %}
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                </li>
                {% endif %}
                <li>
                    <a href="/settings" title="Settings">
                        <i class="bi bi-gear-fill"></i>
                        <span class="nav-label">Settings</span>
                    </a>
                </li>
                {% if is_granted('ROLE_ADMIN') %}
                <li>
                    <a href="{{ path('admin_dashboard') }}" title="Admin">
                        <i class="bi bi-shield-lock-fill"></i>
                        <span class="nav-label">Admin</span>
                    </a>
                </li>
                {% endif %}
                <li>
                    <a href="/logout" class="nav-logout" title="Log out">
                        <i class="bi bi-box-arrow-right"></i>
                        <span class="nav-label">Log out</span>
                    </a>
                </li>
            </ul>
        </div>
    </nav>
    <div id="toast-container" class="toast-container"></div>

    <div class="container" style="padding-top: 4px; padding-bottom: 40px;">
        {% block content %}{% endblock %}
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-brand">
                <img src="/assets/brand/bybit_trader_icon.png" alt="BT" class="footer-icon">
                <div class="footer-text">
                    <strong>Bybit Trader</strong><br>
                    Automated trading bot with LLM analysis
                </div>
            </div>
            <div class="footer-right">
                Bybit API v5 &nbsp;·&nbsp; ChatGPT / DeepSeek<br>
                <span style="opacity:0.5;">© {{ "now"|date("Y") }} Bybit Trader</span>
            </div>
        </div>
    </footer>
    <script>
    (function() {
        var $btn = document.getElementById('profile-dropdown-btn');
        var $menu = document.getElementById('profile-dropdown-menu');
        if (!$btn || !$menu) return;
        $btn.addEventListener('click', function(e) {
            e.stopPropagation();
            document.querySelector('.profile-dropdown')?.classList.toggle('open');
        });
        document.addEventListener('click', function() {
            document.querySelector('.profile-dropdown')?.classList.remove('open');
        });
        $menu.querySelectorAll('.profile-option').forEach(function(a) {
            a.addEventListener('click', function(e) {
                e.preventDefault();
                var id = parseInt(a.getAttribute('data-profile-id'), 10);
                fetch('/api/profile/switch', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({profile_id: id})
                }).then(function(r) { return r.json(); }).then(function(data) {
                    if (data.ok) { window.location.reload(); }
                    else if (window.showToast) { window.showToast(data.error || 'Error', 'error'); }
                }).catch(function() {
                    if (window.showToast) window.showToast('Failed to switch profile', 'error');
                });
            });
        });
    })();
    </script>
</body>
</html>
