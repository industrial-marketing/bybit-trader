<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account — Bybit Trader</title>
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body.register-page { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: var(--bg); }
        .register-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 40px 48px; width: 100%; max-width: 420px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); }
        .register-logo { display: flex; justify-content: center; margin-bottom: 24px; }
        .register-logo img { height: 52px; width: auto; }
        .register-card h1 { color: var(--brand-orange); font-size: 1.35rem; margin: 0 0 6px; text-align: center; }
        .register-card .subtitle { color: var(--muted); font-size: 0.9rem; text-align: center; margin-bottom: 28px; }
        .register-card label { display: block; color: var(--text); font-size: 0.9rem; margin-bottom: 6px; margin-top: 16px; }
        .register-card input { width: 100%; padding: 12px 14px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg); color: var(--text); font-size: 0.95rem; box-sizing: border-box; outline: none; transition: border-color 0.2s; }
        .register-card input:focus { border-color: var(--brand-orange); }
        .register-card button { width: 100%; margin-top: 24px; padding: 12px; background: var(--brand-orange); color: var(--brand-navy); border: none; border-radius: var(--radius-sm); font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: background 0.2s, transform 0.2s; }
        .register-card button:hover { background: #d4a00a; transform: translateY(-1px); }
        .register-card .alert-error { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.4); color: var(--negative); border-radius: var(--radius-sm); padding: 12px 14px; font-size: 0.85rem; margin-bottom: 16px; }
        .register-card .alert-success { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.4); color: var(--positive); border-radius: var(--radius-sm); padding: 12px 14px; font-size: 0.85rem; margin-bottom: 16px; }
        .register-card .login-link { text-align: center; margin-top: 20px; font-size: 0.9rem; color: var(--muted); }
        .register-card .login-link a { color: var(--brand-orange); }
        .btn-google { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 12px 16px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text); font-size: 0.95rem; font-weight: 500; text-decoration: none; cursor: pointer; transition: border-color 0.2s, background 0.2s; }
        .btn-google:hover { border-color: var(--muted); background: rgba(255,255,255,0.04); }
        .register-divider { text-align: center; color: var(--muted); font-size: 0.85rem; margin: 20px 0 8px; }
    </style>
</head>
<body class="register-page">
    <div class="register-card">
        <div class="register-logo">
            <img src="/assets/brand/bybit_trader_logo.png" alt="Bybit Trader">
        </div>
        <h1>Create Account</h1>
        <p class="subtitle">Start your AI trading journey</p>

        <a href="{{ path('connect_google_start') }}" class="btn-google" style="display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:12px;margin-bottom:20px;background:#fff;color:#333;border:1px solid #ddd;border-radius:var(--radius-sm);font-size:0.95rem;font-weight:600;text-decoration:none;transition:background 0.2s;">
            <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Continue with Google
        </a>
        <div style="text-align:center;color:var(--muted);font-size:0.85rem;margin-bottom:16px;">— or —</div>

        {% for message in app.flashes('success') %}
            <div class="alert-success">{{ message }}</div>
        {% endfor %}

        {% if error %}
            <div class="alert-error">{{ error }}</div>
        {% endif %}

        <form method="post">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="{{ last_email }}" autocomplete="email" required autofocus>

            <label for="name">Name</label>
            <input type="text" id="name" name="name" value="{{ last_name }}" autocomplete="name" required minlength="2">

            <label for="password">Password</label>
            <input type="password" id="password" name="password" autocomplete="new-password" required minlength="8">

            <label for="password_confirm">Confirm Password</label>
            <input type="password" id="password_confirm" name="password_confirm" autocomplete="new-password" required>

            <button type="submit">Create Account</button>
        </form>

        <p class="login-link">Already have an account? <a href="/login">Sign in</a></p>
    </div>
</body>
</html>
