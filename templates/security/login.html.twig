<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Bybit Trader</title>
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body.login-page {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            background: var(--bg);
        }
        .login-card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 40px 48px;
            width: 100%;
            max-width: 380px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        .login-logo {
            display: flex;
            justify-content: center;
            margin-bottom: 24px;
        }
        .login-logo img {
            height: 52px;
            width: auto;
        }
        .login-card h1 {
            color: var(--brand-orange);
            font-size: 1.35rem;
            margin: 0 0 6px;
            text-align: center;
        }
        .login-card .subtitle {
            color: var(--muted);
            font-size: 0.9rem;
            text-align: center;
            margin-bottom: 28px;
        }
        .login-card label {
            display: block;
            color: var(--text);
            font-size: 0.9rem;
            margin-bottom: 6px;
            margin-top: 16px;
        }
        .login-card input {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            background: var(--bg);
            color: var(--text);
            font-size: 0.95rem;
            box-sizing: border-box;
            outline: none;
            transition: border-color 0.2s;
        }
        .login-card input:focus {
            border-color: var(--brand-orange);
        }
        .login-card button {
            width: 100%;
            margin-top: 24px;
            padding: 12px;
            background: var(--brand-orange);
            color: var(--brand-navy);
            border: none;
            border-radius: var(--radius-sm);
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s, transform 0.2s;
        }
        .login-card button:hover {
            background: #d4a00a;
            transform: translateY(-1px);
        }
        .login-card .alert-error {
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.4);
            color: var(--negative);
            border-radius: var(--radius-sm);
            padding: 12px 14px;
            font-size: 0.85rem;
            margin-bottom: 16px;
        }
    </style>
</head>
<body class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <img src="/assets/brand/bybit_trader_logo.png" alt="Bybit Trader">
        </div>
        <h1>Bybit Trader</h1>
        <p class="subtitle">Enter your credentials to sign in</p>

        {% if error %}
            <div class="alert-error">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <label for="username">Username</label>
            <input type="text" id="username" name="_username"
                   value="{{ last_username }}" autocomplete="username" autofocus>

            <label for="password">Password</label>
            <input type="password" id="password" name="_password"
                   autocomplete="current-password">

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit">Sign in</button>
        </form>
    </div>
</body>
</html>
